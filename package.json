{
  "name": "agent-loom-workspace",
  "version": "0.2.1",
  "private": true,
  "description": "Repository workspace for the Loom Markdown-native AI work protocol packages.",
  "type": "module",
  "scripts": {
    "smoke:core": "npm --prefix loom-core run smoke",
    "smoke:playbooks": "npm --prefix loom-playbooks run smoke",
    "smoke:packages": "npm run smoke:core && npm run smoke:playbooks",
    "pack:check:core": "npm --prefix loom-core run pack:check",
    "pack:check:playbooks": "npm --prefix loom-playbooks run pack:check",
    "pack:check": "npm run pack:check:core && npm run pack:check:playbooks",
    "test:skill-triggering": "bash tests/skill-triggering/run-all.sh",
    "test:explicit-skill-requests": "bash tests/explicit-skill-requests/run-all.sh"
  },
  "keywords": [
    "opencode",
    "loom",
    "ai-agents",
    "agent-skills",
    "markdown"
  ],
  "author": "z3z1ma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z3z1ma/agent-loom.git"
  },
  "bugs": {
    "url": "https://github.com/z3z1ma/agent-loom/issues"
  },
  "homepage": "https://github.com/z3z1ma/agent-loom#readme"
}
