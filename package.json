{
  "name": "agent-loom-workspace",
  "version": "0.1.11",
  "private": true,
  "description": "Repository workspace for the Loom Markdown-native AI work protocol packages.",
  "type": "module",
  "scripts": {
    "smoke:core": "node loom-core/open-loom-core.mjs --smoke",
    "smoke:playbooks": "node loom-playbooks/open-loom-playbooks.mjs --smoke",
    "smoke:packages": "npm run smoke:core && npm run smoke:playbooks",
    "pack:check:core": "npm pack --dry-run ./loom-core",
    "pack:check:playbooks": "npm pack --dry-run ./loom-playbooks",
    "pack:check": "npm run smoke:packages && npm run pack:check:core && npm run pack:check:playbooks"
  },
  "keywords": [
    "opencode",
    "loom",
    "ai-agents",
    "agent-skills",
    "markdown"
  ],
  "author": "z3z1ma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z3z1ma/agent-loom.git"
  },
  "bugs": {
    "url": "https://github.com/z3z1ma/agent-loom/issues"
  },
  "homepage": "https://github.com/z3z1ma/agent-loom#readme"
}
